# Example environment variables for Render deployment
# Copy these to Render's environment variables section

# Telegram Bot Token (required)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram User ID (required)
ADMIN_ID=7107553688

# Firebase Credentials (required) - choose one method
# Method A (recommended on Railway): paste entire firebase-key.json as one-line JSON
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"telegrambot-f7128",...full_json_here...}

# Method B (file path): only if you deploy with an actual key file in the container
# GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-key.json
