# Example environment variables for Render deployment
# Copy these to Render's environment variables section

# Telegram Bot Token (required)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram User ID (required)
ADMIN_ID=your_telegram_user_id_here

# Firebase Credentials JSON (required)
# Paste the entire content of firebase-key.json as a single-line JSON string
GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"your-project",...}
